# -----------------------------------------------------------------------------
# ARCHIVO DE CONFIGURACIÓN DE EJEMPLO - FRONTEND
# Copia este archivo como '.env' en este mismo directorio y completa los valores.
# Nota: En Vite, todas las variables que se expongan al cliente deben comenzar con VITE_
# -----------------------------------------------------------------------------

# URL base de la API REST del Backend (local o producción)
VITE_API_URL=http://localhost:3000/api

# URL pública del proyecto Supabase (utilizada para cargar recursos estáticos y subidas)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave pública anónima de Supabase (anon key) para autenticación del lado del cliente
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJ.xxxxxxxxxxxxxx-xxxxxxxxxxxxxx
