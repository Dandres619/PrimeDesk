# -----------------------------------------------------------------------------
# ARCHIVO DE CONFIGURACIÓN DE EJEMPLO - BACKEND
# Copia este archivo como '.env' en este mismo directorio y completa los valores.
# -----------------------------------------------------------------------------

# Puerto en el que correrá la API localmente
PORT=3000

# URL de la aplicación frontend (CORS y redirecciones)
FRONTEND_URL=http://localhost:5173

# API Key de Resend (Servicio de envío de correos electrónicos)
RESEND_API_KEY=re_123456789_abcdefghijklmnopqrstuvwxyz

# Remitente de los correos electrónicos enviados por el sistema
SENDER_NAME="Nombre del taller"
SENDER_EMAIL=no-reply@tudominio.com

# Correo de soporte técnico/administrativo
SUPPORT_EMAIL=soporte@tudominio.com

# URL del proyecto Supabase (Almacenamiento de archivos/buckets)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave service_role de Supabase (Evita usar la clave 'anon' pública en el backend)
service_role=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InluaWdmZGxkanliaXpxeXNtbmFmIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MTYxNDEyNSwiZXhwIjoyMDg3MTkwMTI1fQ.xxxxxxxxx-xxxxxxxxxxxxxxx

# URL de conexión a la base de datos PostgreSQL (ej. Supabase Pooler o local)
# Nota: Si usas Supabase, se recomienda habilitar el modo de transacción (puerto 6543)
DATABASE_URL=postgresql://usuario_bd:contraseña_bd@host-del-servidor.pooler.supabase.com:6543/postgres

# Secreto para firmar tokens JWT (JSON Web Tokens)
JWT_SECRET=tu_firma_secreta_altamente_segura_y_larga

# Tiempo de expiración del token JWT
JWT_EXPIRES_IN=8h
