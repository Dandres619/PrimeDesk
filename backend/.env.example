# SendGrid and app environment example
# Copy this file to .env and fill values (DO NOT commit real .env to git)

# SendGrid API key (do NOT commit your real key)
SENDGRID_API_KEY=SG.YOUR_API_KEY_HERE

# Email address to use as sender for transactional emails
SENDER_EMAIL=primedesksena@gmail.com

# Support email to receive contact form messages
SUPPORT_EMAIL=primedesksena@gmail.com

# URL of the frontend application (used in reset links)
FRONTEND_URL=http://localhost:5173
